

LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-localmasterkey
OPENROUTER_API_KEY=sk-or-xxxxx
UI_USERNAME=admin
UI_PASSWORD=change-me

# Required for Admin UI + virtual keys (DB-backed features)
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm?schema=public

# Redis cache (60-80% cost reduction)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
